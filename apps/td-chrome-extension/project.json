{
  "name": "td-chrome-extension",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/td-chrome-extension/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/td-chrome-extension"],
      "options": {
        "commands": [
          "npx nx build td-ui --base-href=/td-ui/",
          "npx nx tsc td-chrome-extension",
          "npx nx run td-chrome-extension:copy-assets",
          "npx nx run td-chrome-extension:copy-td-ui"
        ],
        "parallel": false
      }
    },
    "tsc": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/td-chrome-extension",
        "main": "apps/td-chrome-extension/src/service-worker.ts",
        "tsConfig": "apps/td-chrome-extension/tsconfig.app.json",
        "assets": []
      }
    },
    "copy-assets": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/td-chrome-extension"],
      "options": {
        "commands": [
          "node -e \"const fs=require('fs'); const path=require('path'); const src='apps/td-chrome-extension/src/assets'; const dst='dist/apps/td-chrome-extension'; fs.mkdirSync(dst,{recursive:true}); fs.cpSync(src,dst,{recursive:true});\""
        ],
        "parallel": false
      }
    },
    "copy-td-ui": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/td-chrome-extension/td-ui"],
      "options": {
        "commands": [
          "node -e \"const fs=require('fs'); const src='dist/apps/td-ui/browser'; const dst='dist/apps/td-chrome-extension/td-ui'; fs.rmSync(dst,{recursive:true,force:true}); fs.mkdirSync(dst,{recursive:true}); fs.cpSync(src,dst,{recursive:true});\""
        ],
        "parallel": false
      }
    }
  }
}
