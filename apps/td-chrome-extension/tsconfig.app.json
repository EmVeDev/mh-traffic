{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/apps/td-chrome-extension",
    "rootDir": "./src",

    "target": "ES2022",
    "lib": ["ES2022", "DOM"],

    "module": "ES2022",
    "moduleResolution": "Bundler",

    "sourceMap": false,
    "declaration": false,

    "noEmitOnError": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.spec.ts", "**/*.test.ts"]
}
